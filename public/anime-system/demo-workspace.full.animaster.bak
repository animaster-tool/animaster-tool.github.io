fa7f4a68bb29bf3d23c55414\",\"extent\":\"parent\"},{\"id\":\"pipeline-frame-S2-E2-bt2eb015690b9a47b294c670b39c5c97ba\",\"type\":\"first-frame-node\",\"position\":{\"x\":306.5,\"y\":214.5},\"data\":{\"beatId\":\"S2-E2-B3\",\"beatUid\":\"bt2eb015690b9a47b294c670b39c5c97ba\",\"scriptUid\":\"scf11f26fdfa7f4a68bb29bf3d23c55414\",\"frameImageUrl\":\"http://hdvis.tianeo.com/CompImage/S2-E2-B3_be7505.png\",\"frameMode\":\"generate\",\"isGenerating\":false,\"shotSize\":\"\",\"cameraPosition\":\"\",\"lightAndShadow\":\"\",\"hue\":\"\",\"prompt\":\"\",\"connectedCharacters\":[{\"id\":\"C1\",\"name\":\"Little Red Riding Hood\",\"image\":\"/RefImage/Little_Red_Riding_Hood_868bce.png\"},{\"id\":\"C3\",\"name\":\"Wolf\",\"image\":\"/RefImage/Wolf_bd35a1.png\"}],\"connectedLocation\":{\"id\":\"L2\",\"name\":\"Forest path\",\"image\":\"/RefImage/Forest_path_ee6bca.png\"}},\"parentNode\":\"script-S2-E2-scf11f26fdfa7f4a68bb29bf3d23c55414\",\"extent\":\"parent\"},{\"id\":\"pipeline-video-S2-E2-bt2eb015690b9a47b294c670b39c5c97ba\",\"type\":\"video-node\",\"position\":{\"x\":740.5,\"y\":214.5},\"data\":{\"beatId\":\"S2-E2-B3\",\"beatUid\":\"bt2eb015690b9a47b294c670b39c5c97ba\",\"scriptUid\":\"scf11f26fdfa7f4a68bb29bf3d23c55414\",\"videoUrl\":\"\",\"thumbnailUrl\":\"http://hdvis.tianeo.com/CompImage/S2-E2-B3_be7505.png\",\"duration\":\"\",\"isGenerating\":false,\"connectedFrameId\":\"pipeline-frame-S2-E2-bt2eb015690b9a47b294c670b39c5c97ba\",\"connectedBeatId\":\"S2-E2-B3\",\"connectedFrameImage\":\"http://hdvis.tianeo.com/CompImage/S2-E2-B3_be7505.png\",\"connectedCharacters\":[{\"id\":\"C1\",\"name\":\"Little Red Riding Hood\",\"image\":\"/RefImage/Little_Red_Riding_Hood_868bce.png\"},{\"id\":\"C3\",\"name\":\"Wolf\",\"image\":\"/RefImage/Wolf_bd35a1.png\"}],\"connectedLocation\":{\"id\":\"L2\",\"name\":\"Forest path\",\"image\":\"/RefImage/Forest_path_ee6bca.png\"}},\"parentNode\":\"script-S2-E2-scf11f26fdfa7f4a68bb29bf3d23c55414\",\"extent\":\"parent\"},{\"id\":\"script-S2-E2-sc87bee635