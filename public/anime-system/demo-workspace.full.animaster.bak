 Riding Hood\",\"image\":\"/RefImage/Little_Red_Riding_Hood_75a39b.png\"}],\"connectedLocation\":{\"id\":\"L2\",\"name\":\"Forest path\",\"image\":\"/RefImage/Forest_path_ee6bca.png\"}},\"parentNode\":\"script-S2-E3-scfc3a3514794d4efd9bed2ba37924c208\",\"extent\":\"parent\"},{\"id\":\"pipeline-video-S2-E3-bt7f491b350f82465cbe2f9392c0227e4a\",\"type\":\"video-node\",\"position\":{\"x\":740.5,\"y\":214.5},\"data\":{\"beatId\":\"S2-E3-B4\",\"beatUid\":\"bt7f491b350f82465cbe2f9392c0227e4a\",\"scriptUid\":\"scfc3a3514794d4efd9bed2ba37924c208\",\"videoUrl\":\"\",\"thumbnailUrl\":\"http://hdvis.tianeo.com/CompImage/S2-E3-B4_769e05.png\",\"duration\":\"\",\"isGenerating\":false,\"connectedFrameId\":\"pipeline-frame-S2-E3-bt7f491b350f82465cbe2f9392c0227e4a\",\"connectedBeatId\":\"S2-E3-B4\",\"connectedFrameImage\":\"http://hdvis.tianeo.com/CompImage/S2-E3-B4_769e05.png\",\"connectedCharacters\":[{\"id\":\"C1\",\"name\":\"Little Red Riding Hood\",\"image\":\"/RefImage/Little_Red_Riding_Hood_75a39b.png\"}],\"connectedLocation\":{\"id\":\"L2\",\"name\":\"Forest path\",\"image\":\"/RefImage/Forest_path_ee6bca.png\"}},\"parentNode\":\"script-S2-E3-scfc3a3514794d4efd9bed2ba37924c208\",\"extent\":\"parent\"},{\"id\":\"script-S2-E3-scffeeb1fa7f9840948730cb5cfdb0e13c\",\"type\":\"script-wrapper\",\"position\":{\"x\":4575.748018966613,\"y\":95.52753556239804},\"data\":{\"scriptId\":\"S2-E3-S5\",\"scriptUid\":\"scffeeb1fa7f9840948730cb5cfdb0e13c\",\"width\":1088,\"height\":612},\"parentNode\":\"group-bg-S2-E3\"},{\"id\":\"pipeline-loc-S2-E3-scffeeb1fa7f9840948730cb5cfdb0e13c\",\"type\":\"location-card-node\",\"position\":{\"x\":77.5,\"y\":272},\"data\":{\"beatId\":\"S2-E3-B5\",\"beatUid\":\"btb467d9fefb8d4ffa9fa5690d5a4fbab6\",\"scriptUid\":\"scffeeb1fa7f9840948730cb5cfdb0e13c\",\"locationId\":\"L2\",\"locationName\":\"Forest path\",\"locationImageURL\":\"/RefImage/Forest_path_ee6bca.png\",\"locationDesc\":\"[构图布局] 采用对角线构图，一条蜿蜒的土路从画面右下角向左上角延伸，形成强烈的视觉引导线。[前景描述] 画面右下角是粗壮的橡树树根和几簇随风摇曳的野花，左下角有几只翩翩起舞的蝴蝶。[中景主体及方位] 画面中央是一棵高耸入云的巨大橡树，占据了大部分视野，树旁有一条铺满落叶的分岔小径。[背景深度] 背景是层层叠叠的茂密树冠和森林深处，雾气在树干间隐约可见，拉伸了空间深度。[光影效果] 阳光透过繁密的树冠从正上方滤下，形成一道道清晰的丁达尔光柱，在林间小路上洒下斑驳的光影，整体呈现卡通新海诚风格，线条清晰，明亮的自然光。\"},\"parentNode\":\"script-S2-E3-scffeeb1fa7f9840948730cb5cfdb0e13c\",\"extent\":\"parent\"},{\"id\":\"pipeline-frame-S2-E3-btb467d9fefb8d4ffa9fa5690d5a4fbab6\",\"type\":\"first-frame-node\",\"position\":{\"x\":306.5,\"y\":69},\"data\":{\"beatId\":\"S2-E3-B5\",\"beatUid\":\"btb467d9fefb8d4ffa9fa5690d5a4fbab6\",\"scriptUid\":\"scffeeb1fa7f9840948730cb5cfdb0e13c\",\"frameImageUrl\":\"http://hdvis.tianeo.com/CompImage/S2-E3-B5_92f6c1.png\",\"frameMode\":\"generate\",\"isGenerating\":false,\"shotSize\":\"\",\"cameraPosition\":\"\",\"lightAndShadow\":\"\",\"hue\":\"\",\"prompt\":\"\",\"connectedCharacters\":[],\"connectedLocation\":{\"id\":\"L2\",\"name\":\"Forest path\",\"image\":\"/RefImage/Forest_path_ee6bca.png\"}},\"parentNode\":\"script-S2-E3-scffeeb1fa7f9840948730cb5cfdb0e13c\",\"extent\":\"parent\"},{\"id\":\"pipeline-video-S2-E3-btb467d9fefb8d4ffa9fa5690d5a4fbab6\",\"type\":\"video-node\",\"position\":{\"x\":740.5,\"y\":69},\"data\":{\"beatId\":\"S2-E3-B5\",\"beatUid\":\"btb467d9fefb8d4ffa9fa5690d5a4fbab6\",\"scriptUid\":\"scffeeb1fa7f9840948730cb5cfdb0e13c\",\"videoUrl\":\"\",\"thumbnailUrl\":\"http://hdvis.tianeo.com/CompImage/S2-E3-B5_92f6c1.png\",\"duration\":\"\",\"isGenerating\":false,\"connectedFrameId\":\"pipeline-frame-S2-E3-btb467d9fefb8d4ffa9fa5690d5a4fbab6\",\"connectedBeatId\":\"S2-E3-B5\",\"connectedFrameImage\":\"http://hdvis.tianeo.com/CompImage/S2-E3-B5_92f6c1.png\",\"connectedCharacters\":[],\"connectedLocation\":{\"id\":\"L2\",\"name\":\"Forest path\",\"image\":\"/RefImage/Forest_path_ee6bca.png\"}},\"parentNode\":\"script-S2-E3-scffeeb1fa7f9840948730cb5cfdb0e13c\",\"extent\":\"parent\"},{\"id\":\"pipeline-frame-S2-E3-bt8f1e340eca964f079c7c053181b7c2f6\",\"type\":\"first-frame-node\",\"position\":{\"x\":306.5,\"y\":360},\"data\":{\"beatId\":\"S2-E3-B6\",\"beatUid