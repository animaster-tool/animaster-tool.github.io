.com/CompImage/S2-E4-B5_5d07df.png\",\"duration\":\"\",\"isGenerating\":false,\"connectedFrameId\":\"pipeline-frame-S2-E4-bt555256468c7449efae1a04daf233594f\",\"connectedBeatId\":\"S2-E4-B5\",\"connectedFrameImage\":\"http://hdvis.tianeo.com/CompImage/S2-E4-B5_5d07df.png\",\"connectedCharacters\":[{\"id\":\"C1\",\"name\":\"Little Red Riding Hood\",\"image\":\"/RefImage/Little_Red_Riding_Hood_30d84e.png\"}],\"connectedLocation\":null},\"parentNode\":\"script-S2-E4-sc6151d299e696445cb458d7e0d8320088\",\"extent\":\"parent\"},{\"id\":\"script-S2-E5-scb1923a1ffcf0485b8c98797ee5d1ac8a\",\"type\":\"script-wrapper\",\"position\":{\"x\":28.031497629173828,\"y\":59.81101422495976},\"data\":{\"scriptId\":\"S2-E5-S1\",\"scriptUid\":\"scb1923a1ffcf0485b8c98797ee5d1ac8a\",\"width\":1088,\"height\":612},\"parentNode\":\"group-bg-S2-E5\"},{\"id\":\"pipeline-char-S2-E5-scb1923a1ffcf0485b8c98797ee5d1ac8a-C3\",\"type\":\"character-card-node\",\"position\":{\"x\":77.5,\"y\":184},\"data\":{\"beatId\":\"S2-E5-B1\",\"beatUid\":\"btcda87f82000b428d95213e43b6876cc3\",\"scriptUid\":\"scb1923a1ffcf0485b8c98797ee5d1ac8a\",\"characterId\":\"C3\",\"characterName\":\"Wolf\",\"characterImageURL\":\"/RefImage/Wolf_bd35a1.png\",\"characterDesc\":\"趴下变成正常的狼，四肢着地\"},\"parentNode\":\"script-S2-E5-scb1923a1ffcf0485b8c98797ee5d1ac8a\",\"extent\":\"parent\"},{\"id\":\"pipeline-loc-S2-E5-scb1923a1ffcf0485b8c98797ee5d1ac8a\",\"type\":\"location-card-node\",\"position\":{\"x\":77.5,\"y\":360},\"data\":{\"beatId\":\"S2-E5-B1\",\"beatUid\":\"btcda87f82000b428d95213e43b6876cc3\",\"scriptUid\":\"scb1923a1ffcf0485b8c98797ee5d1ac8a\",\"locationId\":\"L2\",\"locationName\":\"Forest path\",\"locationImageURL\":\"/RefImage/Forest_path_ee6bca.png\",\"locationDesc\":\"[构图布局] 采用对角线构图，一条蜿蜒的土路从画面右下角向左上角延伸，形成强烈的视觉引导线。[前景描述] 画面右下角是粗壮的橡树树根和几簇随风摇曳的野花，左下角有几只翩翩起舞的蝴蝶。[中景主体及方位] 画面中央是一棵高耸入云的巨大橡树，占据了大部分视野，树旁有一条铺满落叶的分岔小径。[背景深度] 背景是层层叠叠的茂密树冠和森林深处，雾气在树干间隐约可见，拉伸了空间深度。[光影效果] 阳光透过繁密的树冠从正上方滤下，形成一道道清晰的丁达尔光柱，在林间小路上洒下斑驳的光影，整体呈现卡通新海诚风格，线条清晰，明亮的自然光。\"},\"parentNode\":\"script-S2-E5-scb1923a1ffcf0485b8c98797ee5d1ac8a\",\"extent\":\"parent\"},{\"id\":\"pipeline-frame-S2-E5-btcda87f82000b428d95213e43b6876cc3\",\"type\":\"first-frame-node\",\"position\":{\"x\":306.5,\"y\":214.5},\"data\":{\"beatId\":\"S2-E5-B1\",\"beatUid\":\"btcda87f82000b428d95213e43b6876cc3\",\"scriptUid\":\"scb1923a1ffcf0485b8c98797ee5d1ac8a\",\"frameImageUrl\":\"http://hdvis.tianeo.com/CompImage/S2-E5-B1_d5a25f.png\",\"frameMode\":\"generate\",\"isGenerating\":false,\"shotSize\":\"\",\"cameraPosition\":\"\",\"lightAndShadow\":\"\",\"hue\":\"\",\"prompt\":\"\",\"connectedCharacters\":[{\"id\":\"C3\",\"name\":\"Wolf\",\"image\":\"/RefImage/Wolf_bd35a1.png\"}],\"connectedLocation\":{\"id\":\"L2\",\"name\":\"Forest path\",\"image\":\"/RefImage/Forest_path_ee6bca.png\"}},\"parentNode\":\"script-S2-E5-scb1923a1ffcf0485b8c98797ee5d1ac8a\",\"extent\":\"parent\"},{\"id\":\"pipeline-video-S2-E5-btcda87f82000b428d95213e43b6876cc3\",\"type\":\"video-node\",\"position\":{\"x\":740.5,\"y\":214.5},\"data\":{\"beatId\":\"S2-E5-B1\",\"beatUid\":\"btcda87f82000b428d95213e43b6876cc3\",\"scriptUid\":\"scb1923a1ffcf0485b8c98797ee5d1ac8a\",\"videoUrl\":\"\",\"thumbnailUrl\":\"http://hdvis.tianeo.com/CompImage/S2-E5-B1_d5a25f.png\",\"duration\":\"\",\"isGenerating\":false,\"connectedFrameId\":\"pipeline-frame-S2-E5-btcda87f82000b428d95213e43b6876cc3\",\"connectedBeatId\":\"S2-E5-B1\",\"connectedFrameImage\":\"http://hdvis.tianeo.com/CompImage/S2-E5-B1_d5a25f.png\",\"connectedCharacters\":[{\"id\":\"C3\",\"name\":\"Wolf\",\"image\":\"/RefImage/Wolf_bd35a1.png\"}],\"connectedLocation\":{\"id\":\"L2\",\"name\":\"Forest path\",\"image\":\"/RefImage/Forest_path_ee6bca.png\"}},\"parentNode\":\"script-S2-E5-scb1923a1ffcf0485b8c98797ee5d1ac8a\",\"extent\":\"parent\"},{\"id\":\"script-S2-E5-scda9843aa5b2248eb9868e825b21c54d8\",\"type\":\"script-wrapper\",\"position\":{\"x\":1163.9685023708262,\"y\":55.842511854133136},\"data\":{\"scriptId\":\"S2-E5-S2\",\"scriptUid\":