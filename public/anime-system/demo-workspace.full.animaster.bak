5-C5\",\"source\":\"pipeline-char-S3-E3-sc169e9a94eadc41f294f0699834238565-C5\",\"target\":\"pipeline-frame-S3-E3-bt274accec9f74440fa882218885873008\",\"sourceHandle\":\"char-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-char-frame-bt274accec9f74440fa882218885873008-pipeline-char-S3-E3-sc169e9a94eadc41f294f0699834238565-C1\",\"source\":\"pipeline-char-S3-E3-sc169e9a94eadc41f294f0699834238565-C1\",\"target\":\"pipeline-frame-S3-E3-bt274accec9f74440fa882218885873008\",\"sourceHandle\":\"char-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-loc-frame-bt274accec9f74440fa882218885873008\",\"source\":\"pipeline-loc-S3-E3-sc169e9a94eadc41f294f0699834238565\",\"target\":\"pipeline-frame-S3-E3-bt274accec9f74440fa882218885873008\",\"sourceHandle\":\"loc-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-frame-video-bt274accec9f74440fa882218885873008\",\"source\":\"pipeline-frame-S3-E3-bt274accec9f74440fa882218885873008\",\"target\":\"pipeline-video-S3-E3-bt274accec9f74440fa882218885873008\",\"sourceHandle\":\"frame-out\",\"targetHandle\":\"video-in\"},{\"id\":\"pe-why-bt8fc9616c80c14f27a74c6da291c37078-bt274accec9f74440fa882218885873008\",\"source\":\"pipeline-frame-S3-E3-bt8fc9616c80c14f27a74c6da291c37078\",\"target\":\"pipeline-frame-S3-E3-bt274accec9f74440fa882218885873008\",\"sourceHandle\":\"frame-why-out\",\"targetHandle\":\"frame-why-in\"},{\"id\":\"vueflow__edge-ctx-char-1774769110497char-out-pipeline-frame-S1-E2-bt26ba46d6966e4e52afae74357e332ca6frame-in\",\"source\":\"ctx-char-1774769110497\",\"target\":\"pipeline-frame-S1-E2-bt26ba46d6966e4e52afae74357e332ca6\",\"sourceHandle\":\"char-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"vueflow__edge-ctx-char-1774858926141char-out-pipeline-frame-S2-E3-bt7f491b350f82465cbe2f9392c0227e4aframe-in\",\"source\":\"ctx-char-1774858926141\",\"target\":\"pipeline-frame-S2-E3-bt7f491b350f82465cbe2f9392c0227e4a\",\"sourceHandle\":\"char-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"vueflow__edge-pipeline-loc-S3-E2-scfcd76ab97316476cbb5085c6e0e08761loc-out-pipeline-frame-S3-E2-bt2823aec8d8974cd9963eb414f31a3d22frame-in\",\"source\":\"pipeline-loc-S3-E2-scfcd76ab97316476cbb5085c6e0e08761\",\"target\":\"pipeline-frame-S3-E2-bt2823aec8d8974cd9963eb414f31a3d22\",\"sourceHandle\":\"loc-out\",\"targetHandle\":\"frame-in\"}],\"deletedNodeIds\":[\"pipeline-frame-S2-E2-S2-E2-B6\",\"pipeline-video-S2-E2-S2-E2-B6\",\"pipeline-frame-S2-E2-S2-E2-B7\",\"pipeline-video-S2-E2-S2-E2-B7\",\"pipeline-char-S2-E2-S2-E2-S2-c1\",\"pipeline-char-S1-E2-S1-E3-S1-c0\",\"ctx-loc-1774182309262\",\"quick-char-1774273476919\",\"drop-loc-Forest path-1774273871482\",\"drop-loc-Forest path-1774273868370\",\"drop-char-Little Red Riding Hood-1774284711178\",\"pipeline-frame-S2-E2-btc8f5d90fb6674cb791f279306858ec9d\",\"pipeline-frame-S2-E2-bt4ecefb3a8e774558a10dae1fb7f1c1db\",\"pipeline-video-S2-E2-bt4ecefb3a8e774558a10dae1fb7f1c1db\",\"pipeline-video-S2-E2-btc8f5d90fb6674cb791f279306858ec9d\",\"ctx-frame-1774700728134\",\"ctx-loc-1774700725840\",\"ctx-char-1774700724129\",\"ctx-video-1774700729871\",\"pipeline-char-S1-E2-sce492f3671ca24bf39d46dfae7ce3a77b-C1\",\"ctx-char-1775628864324\"],\"deletedEdgeIds\":[\"pe-char-frame-S1-E2-B1-pipeline-char-S1-E2-S1-E3-S1-c0\",\"pe-loc-frame-S1-E2-B8\",\"pe-char-frame-S3-E2-B6-pipeline-char-S3-E2-S3-E2-S5-c1\",\"pe-char-frame-S3-E2-B6-pipeline-char-S3-E2-S3-E2-S5-c2\",\"pe-char-frame-S3-E2-B6-pipeline-char-S3-E2-S3-E2-S5-c3\",\"pe-char-frame-S3-E5-B1-pipeline-char-S3-E5-S3-E5-S1-c0\",\"pe-loc-frame-S3-E5-B1\",\"pe-char-frame-S3-E5-B1-pipeline-char-S3-E5-S3-E5-S5-c0\",\"pe-char-frame-S3-E5-B2-pipeline-char-S3-E5-S3-E5-S2-c0\",\"pe-loc-frame-S3-E5-B2\",\"pe-char-frame-S3-E5-B2-pipeline-char-S3-E5-S3-E5-S6-c0\",\"pe-loc-frame-bt555256468c7449efae1a04daf233594f\",\"pe-loc-frame-bt2823aec8d8974cd9963eb414f31a3d22\"]}}","story":"{\"fileContent\": \"{\\\"type\\\": \\\"doc\\\", \\\"content\\\": [{\\\"type\\\": \\\"paragraph\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"marks\\\": [{\\\"type\\\": \\\"segmentMark\\\", \\\"attrs\\\": {\\\"id\\\": \\\"S1\\\", \\\"title\\\": \\\"Segment\\\", \\\"note\\\": \\\"小红帽家的花园\\\", \\\"color\\\": \\\"#0000FF\\\"}}], \\\"text\\\": \\\"In the early morning, Little Red Riding Hood's garden was bathed in soft golden light. Her mother handed her a basket of pastries and said, \\\\\\\"Grandmother is ill. Take these to her, and do not stray from the path.\\\\\\\" Little Red Riding Hood nodded, fastened her bright red cloak, and set off toward Grandmother's house.\\\"}]}, {\\\"type\\\": \\\"paragraph\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"marks\\\": [{\\\"type\\\": \\\"segmentMark\\\", \\\"attrs\\\": {\\\"id\\\": \\\"S2\\\", \\\"title\\\": \\\"Segment\\\", \\\"note\\\": \\\"森林小径\\\", \\\"color\\\": \\\"#8B00FF\\\"}}], \\\"text\\\": \\\"Sunlight filtered through the dense canopy, casting dappled shadows along the winding forest path. Little Red Riding Hood walked along with her basket, humming a cheerful tune. Wildflowers swayed in the breeze, and butterflies danced among the blossoms. She slowed her pace, savoring the peaceful scene.\\\"}]}, {\\\"type\\\": \\\"paragraph\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"marks\\\": [{\\\"type\\\": \\\"segmentMark\\\", \\\"attrs\\\": {\\\"id\\\": \\\"S2\\\", \\\"title\\\": \\\"Segment\\\", \\\"note\\\": \\\"森林小径\\\", \\\"color\\\": \\\"#8B00FF\\\"}}], \\\"text\\\": \\\"Beside a towering oak tree, a wolf suddenly stepped into her path. \\\\\\\"Where are you headed, little girl?\\\\\\\" he asked with a friendly smile. \\\\\\\"I'm going to visit my sick grandmother and bring her some pastries,\\\\\\\" she replied innocently. The wolf tilted his head and pointed toward a flower-lined fork in the road. \\\\\\\"That path is shorter, and you could pick some flowers for your grandmother.\\\\\\\" Little Red Riding Hood hesitated, then decided it was a good idea and turned onto the side trail. The wolf watched her leave, then dashed off in the other direction.\\\"}]}, {\\\"type\\\": \\\"paragraph\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"marks\\\": [{\\\"type\\\": \\\"segmentMark\\\", \\\"attrs\\\": {\\\"id\\\": \\\"S3\\\", \\\"title\\\": \\\"Segment\\\", \\\"note\\\": \\\"外婆的小屋\\\", \\\"color\\\": \\\"#FF0000\\\"}}], \\\"text\\\": \\\"Dusk was falling as Little Red Riding Hood finally reached Grandmother's cottage. She pushed open the creaking wooden door and stepped into the shadowy room. \\\\\\\"Grandmother\\\\\\\" lay in bed, bundled under thick blankets, with only a pair of unusually large eyes visible. \\\\\\\"Grandmother, why are your eyes so big?\\\\\\\" she whispered. \\\\\\\"The better to see you with, my dear.\\\\\\\" \\\\\\\"And why is your mouth so big?\\\\\\\" \\\\\\\"The better to — eat you up!\\\\\\\" The wolf threw off the blankets and lunged. Little Red Riding Hood screamed and fell to the floor.\\\"}]}, {\\\"type\\\": \\\"paragraph\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"text\\\": \\\"The wolf reached Grandmother's cottage first, hid the real Grandmother inside the wardrobe, and disguised himself in bed. Dusk was falling as Little Red Riding Hood finally reached the cottage and stepped into the shadowy room. She whispered, \\\\\\\"Grandmother, why are your eyes so big?\\\\\\\" and then, \\\\\\\"And why is your mouth so big?\\\\\\\" The wolf threw off the blankets and lunged. Little Red Riding Hood screamed and fell to the floor. At that very moment, the cottage door burst open and a passing Huntsman rushed in with his rifle. He overpowered the beast, freed Grandmother from the wardrobe, and Little Red Riding Hood finally threw herself into her grandmother's arms as sunset light filled the room once more.\\\"}]}]}\", \"fileName\": \"Little Red Riding Hood.txt\", \"lastUpdated\": \"2026-03-21T08:04:17.270Z\", \"caseVideoUrl\": \"\", \"storyWithMarks\": {\"type\": \"doc\", \"content\": [{\"type\": \"paragraph\", \"content\": [{\"type\": \"text\", \"marks\": [{\"type\": \"underline\"}, {\"type\": \"eventMark\", \"attrs\": {\"id\": \"S1-E1\", \"title\": \"Event\", \"note\": \"母亲嘱托小红帽\", \"color\": \"#0000FF\"}}, {\"type\": \"segmentMark\", \"attrs\": {\"id\": \"S1\", \"title\": \"Segment\", \"note\": \"小红帽家的花园\", \"color\": \"#0000FF\"}}], \"text\": \"In the early morning, \"}, {\"type\": \"text\", \"marks\": [{\"type\": \"bold\"}, {\"type\": \"underline\"}, {\"type\": \"characterMark\", \"attrs\": {\"id\": \"1774072991725\", \"title\": \"Character\", \"note\": \"Little Red Riding Hood\"}}, {\"type\": \"eventMark\", \"attrs\": {\"id\": \"S1-E1\", \"title\": \"Event\", \"note\": \"母亲嘱托小红帽\", \"color\": \"#0000FF\"}}, {\"type\": \"segmentMark\", \"attrs\": {\"id\": \"S1\", \"title\": \"Segment\", \"note\": \"小红帽家的花园\", \"color\": \"#0000FF\"}}], \"text\": \"Little Red Riding Hood\"}, {\"type\": \"text\", \"marks\": [{\"type\": \"underline\"}, {\"type\": \"eventMark\", \"attrs\": {\"id\": \"S1-E1\", \"title\": \"Event\", \"note\": \"母亲嘱托小红帽\", \"color\": \"#0000FF\"}}, {\"type\": \"segmentMark\", \"attrs\": {\"id\": \"S1\", \"title\": \"Segment\", \"note\": \"小红帽家的花园\", \"color\": \"#0000FF\"}}], \"text\": \"'s \"}, {\"type\": \"text\", \"marks\": [{\"type\": \"bold\"}, {\"type\": \"underline\"}, {\"type\": \"locationMark\", \"attrs\": {\"id\": \"1774072991725\", \"title\": \"Location\", \"note\": \"garden\"}}, {\"type\": \"eventMark\", \"attrs\": {\"id\": \"S1-E1\", \"title\": \"Event\", \"note\": \"母亲嘱托小红帽\", \"color\": \"#0000FF\"}}, {\"type\": \"segmentMark\", \"attrs\": {\"id\": \"S1\", \"title\": \"Segment\", \"note\": \"小红帽家的花园\", \"color\": \"#0000FF\"}}], \"text\": \"garden\"}, {\"type\": \"text\", \"marks\": [{\"type\": \"underline\"}, {\"type\": \"eventMark\", \"attrs\": {\"id\": \"S1-E1\", \"title\": \"Event\", \"note\": \"母亲嘱托小红帽\", \"color\": \"#0000FF\"}}, {\"type\": \"segmentMark\", \"attrs\": {\"id\": \"S1\", \"title\": \"Segment\", \"note\": \"小红帽家的花园\", \"color\": \"#0000FF\"}}], \"text\": \" was bathed in soft golden l