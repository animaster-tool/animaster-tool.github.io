_Riding_Hood_14c06c.png\",\"characterDesc\":\"同一角色，特写（面部）构图，平视，温暖的微笑，双手向上举起，面朝自己的行动方向，手持编织篮，卡通新海诚动漫风格，保持角色设计一致，背景颜色RGB（0，255，0）\"},\"parentNode\":\"script-S1-E2-sce492f3671ca24bf39d46dfae7ce3a77b\",\"extent\":\"parent\"}],\"edges\":[{\"id\":\"pe-loc-frame-bt7910ac174a6b4596ac5277a51eeb2086\",\"source\":\"pipeline-loc-S1-E1-sc91bce814b4804698b5d952468cbd6ee8\",\"target\":\"pipeline-frame-S1-E1-bt7910ac174a6b4596ac5277a51eeb2086\",\"sourceHandle\":\"loc-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-frame-video-bt7910ac174a6b4596ac5277a51eeb2086\",\"source\":\"pipeline-frame-S1-E1-bt7910ac174a6b4596ac5277a51eeb2086\",\"target\":\"pipeline-video-S1-E1-bt7910ac174a6b4596ac5277a51eeb2086\",\"sourceHandle\":\"frame-out\",\"targetHandle\":\"video-in\"},{\"id\":\"pe-loc-frame-bt211e502757cd48acb9ba7cef53de4f9b\",\"source\":\"pipeline-loc-S1-E1-sc91bce814b4804698b5d952468cbd6ee8\",\"target\":\"pipeline-frame-S1-E1-bt211e502757cd48acb9ba7cef53de4f9b\",\"sourceHandle\":\"loc-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-frame-video-bt211e502757cd48acb9ba7cef53de4f9b\",\"source\":\"pipeline-frame-S1-E1-bt211e502757cd48acb9ba7cef53de4f9b\",\"target\":\"pipeline-video-S1-E1-bt211e502757cd48acb9ba7cef53de4f9b\",\"sourceHandle\":\"frame-out\",\"targetHandle\":\"video-in\"},{\"id\":\"pe-why-bt7910ac174a6b4596ac5277a51eeb2086-bt211e502757cd48acb9ba7cef53de4f9b\",\"source\":\"pipeline-frame-S1-E1-bt7910ac174a6b4596ac5277a51eeb2086\",\"target\":\"pipeline-frame-S1-E1-bt211e502757cd48acb9ba7cef53de4f9b\",\"sourceHandle\":\"frame-why-out\",\"targetHandle\":\"frame-why-in\"},{\"id\":\"pe-loc-frame-btc589858aebb446eebe687f2c9bdf95eb\",\"source\":\"pipeline-loc-S1-E1-sc08a3244d3e46459c84999e9d94ec3aa3\",\"target\":\"pipeline-frame-S1-E1-btc589858aebb446eebe687f2c9bdf95eb\",\"sourceHandle\":\"loc-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-frame-video-btc589858aebb446eebe687f2c9bdf95eb\",\"source\":\"pipeline-frame-S1-E1-btc589858aebb446eebe687f2c9bdf95eb\",\"target\":\"pipeline