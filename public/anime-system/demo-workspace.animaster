-frame-btfefa3b67f3374840802d9b33f8d37736\",\"source\":\"pipeline-loc-S1-E2-sc6c6f6cd812fb492fbe4d09468a365ad7\",\"target\":\"pipeline-frame-S1-E2-btfefa3b67f3374840802d9b33f8d37736\",\"sourceHandle\":\"loc-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-frame-video-btfefa3b67f3374840802d9b33f8d37736\",\"source\":\"pipeline-frame-S1-E2-btfefa3b67f3374840802d9b33f8d37736\",\"target\":\"pipeline-video-S1-E2-btfefa3b67f3374840802d9b33f8d37736\",\"sourceHandle\":\"frame-out\",\"targetHandle\":\"video-in\"},{\"id\":\"pe-char-frame-bt48a4b13d352a405f9a0c16b0cd52c819-pipeline-char-S1-E2-sc7817bbd261d24930b7ffc583d3f5a6c2-C1\",\"source\":\"pipeline-char-S1-E2-sc7817bbd261d24930b7ffc583d3f5a6c2-C1\",\"target\":\"pipeline-frame-S1-E2-bt48a4b13d352a405f9a0c16b0cd52c819\",\"sourceHandle\":\"char-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-loc-frame-bt48a4b13d352a405f9a0c16b0cd52c819\",\"source\":\"pipeline-loc-S1-E2-sc7817bbd261d24930b7ffc583d3f5a6c2\",\"target\":\"pipeline-frame-S1-E2-bt48a4b13d352a405f9a0c16b0cd52c819\",\"sourceHandle\":\"loc-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-frame-video-bt48a4b13d352a405f9a0c16b0cd52c819\",\"source\":\"pipeline-frame-S1-E2-bt48a4b13d352a405f9a0c16b0cd52c819\",\"target\":\"pipeline-video-S1-E2-bt48a4b13d352a405f9a0c16b0cd52c819\",\"sourceHandle\":\"frame-out\",\"targetHandle\":\"video-in\"},{\"id\":\"pe-char-frame-bt55cd3f240f5148cbbfab9487161870aa-pipeline-char-S1-E2-sc34583a84f7cb400f95a1065b35a6911d-C1\",\"source\":\"pipeline-char-S1-E2-sc34583a84f7cb400f95a1065b35a6911d-C1\",\"target\":\"pipeline-frame-S1-E2-bt55cd3f240f5148cbbfab9487161870aa\",\"sourceHandle\":\"char-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-loc-frame-bt55cd3f240f5148cbbfab9487161870aa\",\"source\":\"pipeline-loc-S1-E2-sc34583a84f7cb400f95a1065b35a6911d\",\"target\":\"pipeline-frame-S1-E2-bt55cd3f240f5148cbbfab9487161870aa\",\"sourceHandle\":\"loc-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-frame-video-bt55cd3f240f5148cbbfab9487161870aa\",\"source\":\"pipeline-frame-S1-E2-bt55cd3f240f5148cbbfab9487161870aa\",\"target\":\"pipeline-video-S1-E2-bt55cd3f240f5148cbbfab9487161870aa\",\"sourceHandle\":\"frame-out\",\"targetHandle\":\"video-in\"},{\"id\":\"pe-char-frame-bt83e83de2473349ff96a58fd490823f2f-pipeline-char-S1-E2-scfd34b00df43f4e0c9a85f77ae93d97d4-C1\",\"source\":\"pipeline-char-S1-E2-scfd34b00df43f4e0c9a85f77ae93d97d4-C1\",\"target\":\"pipeline-frame-S1-E2-bt83e83de2473349ff96a58fd490823f2f\",\"sourceHandle\":\"char-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-loc-frame-bt83e83de2473349ff96a58fd490823f2f\",\"source\":\"pipeline-loc-S1-E2-scfd34b00df43f4e0c9a85f77ae93d97d4\",\"target\":\"pipeline-frame-S1-E2-bt83e83de2473349ff96a58fd490823f2f\",\"sourceHandle\":\"loc-out\",\"targetHandle\":\"frame-in\"},{\"id\":\"pe-frame-video-bt83e83de2473349ff96a58fd490823f2f\",\"source\":\"pipeline-frame-S1-E2-bt83e83de2473349ff96a58fd490823f2f\",\"target\":\"pipeline-video-S1-E2-bt83e83de2473349ff96a58fd490823f2f\",\"sourceHandle\":\"frame-out\",\"targetHandle\":\"video-in\"},{\"id\":\"vueflow__edge-ctx-char-1774769110497char-out-pipeline-frame-S1-E2-bt26ba46d6966e4e52afae74357e332ca6frame-in\",\"source\":\"ctx-char-1774769110497\",\"target\":\"pipeline-frame-S1-E2-bt26ba46d6966e4e52afae74357e332ca6\",\"sourceHandle\":\"char-out\",\"targetHandle\":\"frame-in\"}],\"deletedNodeIds\":[],\"deletedEdgeIds\":[]}}", "story": "{\"fileContent\": \"{\\\"type\\\": \\\"doc\\\", \\\"content\\\": [{\\\"type\\\": \\\"paragraph\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"marks\\\": [{\\\"type\\\": \\\"segmentMark\\\", \\\"attrs\\\": {\\\"id\\\": \\\"S1\\\", \\\"title\\\": \\\"Segment\\\", \\\"note\\\": \\\"小红帽家的花园\\\", \\\"color\\\": \\\"#0000FF\\\"}}], \\\"text\\\": \\\"In the early morning, Little Red Riding Hood's garden was bathed in soft golden light. Her mother handed her a basket of pastries and said, \\\\\\\"Grandmother is ill. Take these to her, and do not stray from the path.\\\\\\\" Little Red Riding Hood nodded, fastened her bright red cloak, and set off toward Grandmother's house.\\\"}]}, {\\\"type\\\": \\\"paragraph\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"marks\\\": [{\\\"type\\\": \\\"segmentMark\\\", \\\"attrs\\\": {\\\"id\\\": \\\"S2\\\", \\\"title\\\": \\\"Segment\\\", \\\"note\\\": \\\"森林小径\\\", \\\"color\\\": \\\"#8B00FF\\\"}}], \\\"text\\\": \\\"Sunlight filtered through the dense canopy, casting dappled shadows along the winding forest path. Little Red Riding Hood walked along with her basket, humming a cheerful tune. Wildflowers swayed in the breeze, and butterflies danced among the blossoms. She slowed her pace, savoring the peaceful scene.\\\"}]}, {\\\"type\\\": \\\"paragraph\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"marks\\\": [{\\\"type\\\": \\\"segmentMark\\\", \\\"attrs\\\": {\\\"id\\\": \\\"S2\\\", \\\"title\\\": \\\"Segment\\\", \\\"note\\\": \\\"森林小径\\\", \\\"color\\\": \\\"#8B00FF\\\"}}], \\\"text\\\": \\\"Beside a towering oak tree, a wolf suddenly stepped into her path. \\\\\\\"Where are you headed, little girl?\\\\\\\" he asked with a friendly smile. \\\\\\\"I'm going to visit my sick grandmother and bring her some pastries,\\\\\\\" she replied innocently. The wolf tilted his head and pointed toward a flower-lined fork in the road. \\\\\\\"That path is shorter, and you could pick some flowers for your grandmother.\\\\\\\" Little Red Riding Hood hesitated, then decided it was a good idea and turned onto the side trail. The wolf watched her leave, then dashed off in the other direction.\\\"}]}, {\\\"type\\\": \\\"paragraph\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"marks\\\": [{\\\"type\\\": \\\"segmentMark\\\", \\\"attrs\\\": {\\\"id\\\": \\\"S3\\\", \\\"title\\\": \\\"Segment\\\", \\\"note\\\": \\\"外婆的小屋\\\", \\\"color\\\": \\\"#FF0000\\\"}}], \\\"text\\\": \\\"Dusk was falling as Little Red Riding Hood finally reached Grandmother's cottage. She pushed open the creaking wooden door and stepped into the shadowy room. \\\\\\\"Grandmother\\\\\\\" lay in bed, bundled under thick blankets, with only a pair of unusually large eyes visible. \\\\\\\"Grandmother, why are your eyes so big?\\\\\\\" she whispered. \\\\\\\"The better to see you with, my dear.\\\\\\\" \\\\\\\"And why is your mouth so big?\\\\\\\" \\\\\\\"The better to — eat you up!\\\\\\\" The wolf threw off the blankets and lunged. Little Red Riding Hood screamed and fell to the floor.\\\"}]}, {\\\"type\\\": \\\"paragraph\\\", \\\"content\\\": [{\\\"type\\\": \\\"text\\\", \\\"text\\\": \\\"The wolf reached Grandmother's cottage first, hid the real Grandmother inside the wardrobe, and disguised himself in bed. Dusk was falling as Little Red Riding Hood finally reached the cottage and stepped into the shadowy room. She whispered, \\\\\\\"Grandmother, why are your eyes so big?\\\\\\\" and then, \\\\\\\"And why is your mouth so big?\\\\\\\" The wolf threw off the blankets and lunged. Little Red Riding Hood screamed and fell to the floor. At that very moment, the cottage door burst open and a passing Huntsman rushed in with his rifle. He overpowered the beast, freed Grandmother from the wardrobe, and Little Red Riding Hood finally threw herself into her grandmother's arms as sunset light filled the room once more.\\\"}]}]}\", \"fileName\": \"Little Red Riding Hood.txt\", \"lastUpdated\": \"2026-03-21T08:04:17.270Z\", \"caseVideoUrl\": \"\", \"storyWithMarks\": {\"type\": \"doc\", \"content\": [{\"type\": \"paragraph\", \"content\": [{\"type\": \"text\", \"marks\": [{\"type\": \"underline\"}, {\"type\": \"eventMark\", \"attrs\": {\"id\": \"S1-E1\", \"title\": \"Event\", \"note\": \"母亲嘱托小红帽\", \"color\": \"#0000FF\"}}, {\"type\": \"segmentMark\", \"attrs\": {\"id\": \"S1\", \"title\": \"Segment\", \"note\": \"小红帽家的花园\", \"color\": \"#0000FF\"}}], \"text\": \"In the early morning, \"}, {\"type\": \"text\", \"marks\": [{\"type\": \"bold\"}, {\"type\": \"underline\"}, {\"type\": \"characterMark\", \"a